# ACME DNS Provider Credentials
# Uncomment the provider you want to use

# DNSPod (used in this example)
DP_Id="your-dnspod-id"
DP_Key="your-dnspod-api-key"

# Cloudflare
# CF_Key="your-cloudflare-global-api-key"
# CF_Email="your-cloudflare-email@example.com"

# Alibaba Cloud DNS
# Ali_Key="your-aliyun-access-key"
# Ali_Secret="your-aliyun-access-secret"

# AWS Route53
# AWS_ACCESS_KEY_ID="your-aws-access-key"
# AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
